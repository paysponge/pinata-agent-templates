---
import BaseHead from '../components/BaseHead.astro';
import Link from '../components/ui/Link.astro';
import Text from '../components/ui/Text.astro';

interface Props {
  title: string;
  description?: string;
  fullWidth?: boolean;
  brand?: string;
  links?: Array<{ label: string; href: string }>;
}

const { title, description, fullWidth = false, brand = 'Web Master', links } = Astro.props;
const base = import.meta.env.BASE_URL;
const navLinks = links ?? [
  { label: 'Home', href: base },
  { label: 'Blog', href: `${base}/blog` },
  { label: 'Templates', href: `${base}/template` },
];
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead title={title} description={description} />
  </head>
  <body>
    <nav>
      <div class="nav-inner">
        <Link href={base} class="brand">{brand}<span class="dot">.</span></Link>
        <div class="nav-links">
          {navLinks.map(link => (
            <Link href={link.href}><Text variant="link">{link.label}</Text></Link>
          ))}
        </div>
      </div>
    </nav>
    <main class:list={[{ contained: !fullWidth }]}>
      <slot />
    </main>
    <footer>
      <div class="footer-inner">
        <Text variant="caption">Built with Astro + SQLite</Text>
      </div>
    </footer>
  </body>
</html>

<style>
  nav {
    position: sticky;
    top: 0;
    z-index: 100;
    background: color-mix(in srgb, var(--bg) 85%, transparent);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border-bottom: 1px solid var(--border);
  }

  .nav-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    max-width: var(--max-w);
    margin: 0 auto;
    padding: 1rem 1.5rem;
  }

  nav :global(.brand) {
    font-family: var(--display);
    font-weight: 700;
    font-size: 1.15rem;
    letter-spacing: -0.02em;
  }

  .dot {
    color: var(--accent);
  }

  .nav-links {
    display: flex;
    gap: 2rem;
  }

  main.contained {
    max-width: var(--max-w);
    margin: 0 auto;
    padding: 2rem 1.5rem;
  }

  footer {
    border-top: 1px solid var(--border);
  }

  .footer-inner {
    max-width: var(--max-w);
    margin: 0 auto;
    padding: 2.5rem 1.5rem;
    text-align: center;
  }
</style>
