---
import Layout from '../../layouts/Layout.astro';
import WaitlistForm from '../../components/WaitlistForm.astro';
import Button from '../../components/ui/Button.astro';
import Link from '../../components/ui/Link.astro';

const base = import.meta.env.BASE_URL;

const features = [
  { icon: '\u26A1', title: 'Lightning Fast', desc: 'Server-rendered pages load in milliseconds. No hydration delay, no layout shift.' },
  { icon: '\u2699\uFE0F', title: 'Zero Config', desc: 'Convention over configuration. Sensible defaults that get out of your way.' },
  { icon: '\uD83D\uDD12', title: 'Type Safe', desc: 'TypeScript from templates to API routes. Catch errors before they ship.' },
  { icon: '\uD83D\uDD0D', title: 'SEO Ready', desc: 'Server-rendered HTML with full control over meta tags and structured data.' },
  { icon: '\uD83C\uDF10', title: 'Edge Ready', desc: 'Deploy to Vercel, Netlify, Cloudflare, or any Node.js host.' },
  { icon: '\uD83D\uDD13', title: 'Open Source', desc: 'MIT licensed. Fork it, extend it, make it yours.' },
];

const stats = [
  { value: '<50ms', label: 'Avg Response' },
  { value: '0 KB', label: 'Client JS' },
  { value: '99.9%', label: 'Uptime' },
  { value: '10K+', label: 'Sites Built' },
];
---

<Layout
  title="Starter — Web Master Templates"
  fullWidth
  brand="Launchpad"
  links={[
    { label: 'Features', href: '#features' },
    { label: 'Stats', href: '#stats' },
    { label: 'Get Started', href: '#cta' },
    { label: '\u2190 Templates', href: `${base}/template` },
  ]}
>
  <!-- Hero -->
  <section class="hero">
    <div class="inner hero-split">
      <div class="hero-content">
        <span class="hero-badge">Now in public beta</span>
        <h1 class="hero-title">Ship your idea,<br />not your weekend<span class="dot">.</span></h1>
        <p class="hero-sub">From zero to live in minutes. Built on Astro &mdash; server-rendered, fast by default, zero client-side JavaScript.</p>
        <div class="hero-actions">
          <Link href="#cta"><Button variant="primary">Get Started Free</Button></Link>
          <Link href="#features"><Button variant="secondary">See Features</Button></Link>
        </div>
      </div>
      <div class="hero-visual">
        <img src="https://pamadd.mypinata.cloud/ipfs/bafybeif5zr4xibk7fgxqttssqehfg5kdy44bnl2vxvmhilouik22u6wufe/laptopwork.jpg" alt="Top-down view of a person managing finances with a laptop and calculator" class="hero-image" />
      </div>
    </div>
  </section>

  <!-- Features -->
  <section id="features" class="features">
    <div class="inner">
      <h2 class="section-title">Everything you need</h2>
      <p class="section-sub">A complete toolkit for building modern websites. Nothing extra, nothing missing.</p>
      <div class="feature-grid">
        {features.map((f, i) => (
          <div class="feature-card" style={`animation-delay: ${0.1 + i * 0.08}s`}>
            <span class="feature-icon">{f.icon}</span>
            <h3>{f.title}</h3>
            <p>{f.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Stats -->
  <section id="stats" class="stats">
    <div class="inner">
      <div class="stats-grid">
        {stats.map(s => (
          <div class="stat">
            <span class="stat-value">{s.value}</span>
            <span class="stat-label">{s.label}</span>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section id="cta" class="cta">
    <div class="inner">
      <h2 class="section-title">Ready to build?</h2>
      <p class="section-sub">Join the waitlist and be the first to launch.</p>
      <WaitlistForm />
    </div>
  </section>
</Layout>

<style>
  .inner {
    max-width: var(--max-w);
    margin: 0 auto;
    padding-left: 1.5rem;
    padding-right: 1.5rem;
  }

  .section-title {
    font-family: var(--display);
    font-size: clamp(1.8rem, 4vw, 2.5rem);
    font-weight: 800;
    letter-spacing: -0.03em;
    line-height: 1.1;
  }

  .section-sub {
    color: var(--text-muted);
    font-size: 1.05rem;
    margin-top: 0.5rem;
  }

  /* Hero */
  .hero {
    padding: 6rem 1.5rem 5rem;
    text-align: center;
    background:
      radial-gradient(ellipse at 25% 80%, color-mix(in srgb, var(--accent) 8%, transparent) 0%, transparent 50%),
      radial-gradient(ellipse at 75% 20%, color-mix(in srgb, #4060ff 5%, transparent) 0%, transparent 50%),
      var(--bg);
  }

  .hero .inner.hero-split {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 3rem;
    align-items: center;
    text-align: left;
    animation: fade-in 0.6s ease both;
  }

  .hero-content {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 1.25rem;
  }

  .hero-visual {
    position: relative;
    border-radius: var(--radius);
    overflow: hidden;
    box-shadow: 0 20px 40px rgba(0,0,0,0.3);
  }

  .hero-image {
    width: 100%;
    height: auto;
    display: block;
    object-fit: cover;
    aspect-ratio: 4/3;
  }

  @media (max-width: 768px) {
    .hero .inner.hero-split {
      grid-template-columns: 1fr;
      text-align: center;
    }
    .hero-content {
      align-items: center;
    }
  }

  .hero-badge {
    font-size: 0.8rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--accent);
    border: 1px solid color-mix(in srgb, var(--accent) 30%, var(--border));
    border-radius: 999px;
    padding: 0.3rem 1rem;
  }

  .hero-title {
    font-family: var(--display);
    font-size: clamp(2.5rem, 7vw, 4.5rem);
    font-weight: 800;
    letter-spacing: -0.03em;
    line-height: 1.05;
  }

  .dot {
    color: var(--accent);
  }

  .hero-sub {
    font-size: 1.15rem;
    color: var(--text-muted);
    line-height: 1.7;
    max-width: 520px;
  }

  .hero-actions {
    display: flex;
    gap: 0.75rem;
    margin-top: 0.5rem;
    flex-wrap: wrap;
    justify-content: center;
  }

  /* Features */
  .features {
    padding: 5rem 0;
    border-top: 1px solid var(--border);
    scroll-margin-top: 60px;
  }

  .features .inner {
    text-align: center;
  }

  .feature-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
    gap: 1.25rem;
    margin-top: 2.5rem;
    text-align: left;
  }

  .feature-card {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 1.75rem;
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
    transition: transform 0.2s, border-color 0.2s, box-shadow 0.2s;
    animation: fade-up 0.5s ease both;
  }

  .feature-card:hover {
    transform: translateY(-4px);
    border-color: color-mix(in srgb, var(--accent) 40%, var(--border));
    box-shadow: 0 8px 30px color-mix(in srgb, var(--accent) 8%, transparent);
  }

  .feature-icon {
    font-size: 1.5rem;
  }

  .feature-card h3 {
    font-family: var(--display);
    font-size: 1.1rem;
    font-weight: 700;
  }

  .feature-card p {
    color: var(--text-muted);
    font-size: 0.9rem;
    line-height: 1.55;
  }

  /* Stats */
  .stats {
    padding: 4rem 0;
    background: var(--surface);
    border-top: 1px solid var(--border);
    border-bottom: 1px solid var(--border);
    scroll-margin-top: 60px;
  }

  .stats-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 2rem;
    text-align: center;
  }

  .stat {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  .stat-value {
    font-family: var(--display);
    font-size: clamp(1.75rem, 4vw, 2.5rem);
    font-weight: 800;
    letter-spacing: -0.02em;
    color: var(--accent);
  }

  .stat-label {
    font-size: 0.85rem;
    color: var(--text-muted);
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }

  @media (max-width: 600px) {
    .stats-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  /* CTA */
  .cta {
    padding: 5rem 0;
    text-align: center;
    scroll-margin-top: 60px;
  }

  .cta .inner {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.5rem;
  }
</style>
