---
interface Props {
  href: string;
  class?: string;
  [key: string]: any;
}
const { href, class: className, ...rest } = Astro.props;
---
<a href={href} class:list={[className]} data-astro-prefetch="hover" {...rest}>
  <slot />
</a>

<style>
  a {
    text-decoration: none;
    color: inherit;
  }
</style>
