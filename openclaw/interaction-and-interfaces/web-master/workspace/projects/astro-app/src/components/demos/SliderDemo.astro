<div class="slider-demo">
  <div class="controls">
    <label for="range-slider">
      Time range: <strong id="range-label">7 days</strong>
    </label>
    <input type="range" id="range-slider" min="1" max="30" value="7" />
  </div>
  <div class="chart" id="chart"></div>
  <div class="stats" id="stats"></div>
</div>

<script>
  document.addEventListener('astro:page-load', () => {
    const slider = document.getElementById('range-slider') as HTMLInputElement;
    if (!slider) return;
    const label = document.getElementById('range-label')!;
    const chart = document.getElementById('chart')!;
    const stats = document.getElementById('stats')!;

    const labels = ['Mon', 'Tue', 'Wed', 'Thu', 'Fri', 'Sat', 'Sun'];

    function generateData(days: number) {
      let seed = days * 13;
      return labels.map(() => {
        seed = (seed * 16807 + 7) % 2147483647;
        return 30 + (seed % 70);
      });
    }

    function render(days: number) {
      label.textContent = `${days} day${days > 1 ? 's' : ''}`;
      const data = generateData(days);
      const max = Math.max(...data);
      const total = data.reduce((a, b) => a + b, 0);

      chart.innerHTML = data.map((v, i) => `
        <div class="bar-col">
          <div class="bar" style="height: ${(v / max) * 100}%"></div>
          <span class="bar-label">${labels[i]}</span>
        </div>
      `).join('');

      stats.textContent = `${total.toLocaleString()} visits over ${days} day${days > 1 ? 's' : ''}`;
    }

    slider.addEventListener('input', () => render(Number(slider.value)));
    render(7);
  });
</script>

<style>
  .slider-demo {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 1.5rem;
    margin: 1rem 0;
  }

  .controls {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 1rem;
  }

  .controls label {
    font-size: 0.9rem;
  }

  input[type='range'] {
    width: 180px;
    accent-color: var(--accent);
  }

  .chart {
    display: flex;
    align-items: flex-end;
    gap: 0.5rem;
    height: 120px;
    padding: 0 0.25rem;
    margin-bottom: 0.75rem;
  }

  .bar-col {
    flex: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    height: 100%;
    justify-content: flex-end;
  }

  .bar {
    width: 100%;
    background: var(--accent);
    border-radius: 4px 4px 0 0;
    transition: height 0.2s ease;
    min-height: 4px;
  }

  .bar-label {
    font-size: 0.7rem;
    color: var(--text-muted);
    margin-top: 0.25rem;
  }

  .stats {
    text-align: center;
    font-size: 0.85rem;
    color: var(--text-muted);
  }
</style>
